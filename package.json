{
  "name": "professional-chatgpt-clone",
  "version": "1.0.0",
  "type": "module",
  "description": "Enterprise-grade AI chatbot with Ollama integration",
  "main": "server/src/index.js",
  "scripts": {
    "start": "node server/src/index.js",
    "dev": "nodemon server/src/index.js",
    "client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "install-all": "npm install && cd client && npm install",
    "lint": "eslint . --ext .js,.jsx",
    "format": "prettier --write \"**/*.{js,jsx,json,css}\"",
    "test": "node --test server/tests/**/*.test.js",
    "server-only": "node server/src/index.js"
  },
  "keywords": [
    "chatgpt",
    "ai",
    "chatbot",
    "ollama",
    "streaming",
    "enterprise",
    "react",
    "express"
  ],
  "author": "Your Organization",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourorg/professional-chatgpt-clone.git"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "eslint": "^8.54.0",
    "prettier": "^3.1.0"
  }
}
